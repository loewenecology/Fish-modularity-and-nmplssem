# Variation partitioning

vp_mod04_Tjur <- varPart(A = mod04_A_Tjur,
                         B = mod04_B_Tjur,
                         C = mod04_C_Tjur,
                         AB = mod04_AB_Tjur,
                         AC = mod04_AC_Tjur,
                         BC = mod04_BC_Tjur,
                         ABC = mod04_ABC_Tjur,
                         A.name = "Connectivity",
                         B.name = "Climate",
                         C.name = "Habitat")

# Euler plot

vp_mod04_Tjur.euler <- euler(c("Connectivity" = round(if(vp_mod04_Tjur$Proportion[1] < 0) {0} else {vp_mod04_Tjur$Proportion[1]}, digits = 5), #a
                               "Climate" = round(if(vp_mod04_Tjur$Proportion[2] < 0) {0} else {vp_mod04_Tjur$Proportion[2]}, digits = 5), #b
                               "Habitat" = round(if(vp_mod04_Tjur$Proportion[3] < 0) {0} else {vp_mod04_Tjur$Proportion[3]}, digits = 5), #c
                               "Connectivity&Climate"= round(if(vp_mod04_Tjur$Proportion[4] < 0) {0} else {vp_mod04_Tjur$Proportion[4]}, digits = 5), #d
                               "Climate&Habitat" = round(if(vp_mod04_Tjur$Proportion[5] < 0) {0} else {vp_mod04_Tjur$Proportion[5]}, digits = 5), #e
                               "Connectivity&Habitat" = round(if(vp_mod04_Tjur$Proportion[6] < 0) {0} else {vp_mod04_Tjur$Proportion[6]}, digits = 5), #f
                               "Connectivity&Climate&Habitat" = round(if(vp_mod04_Tjur$Proportion[7] < 0) {0} else {vp_mod04_Tjur$Proportion[7]}, digits = 5)), #g
                               shape="ellipse")

vp_mod04_Tjur.euler.p <- plot(vp_mod04_Tjur.euler,
                              fill=list(fill=c("#8dd3c7","#ffffb3","#bebada"), alpha=c(0.65,0.65,0.65)), 
                              edges=list(lty=1:3, lex=2), quantities=list(cex=0.5), adjust_labels = TRUE)
                              
