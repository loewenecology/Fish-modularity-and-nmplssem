#### Multilevel categorical ####

# rows of the path matrix

Connectivity = c(0,0,0,0)
Habitat = c(0,0,0,0)
Climate = c(0,0,0,0)
Categ = c(1,1,1,0)

# vector of modes A reflective and B composite

sem_modes = c("B","B","B","B")

# path matrix (inner model)

sem_path = rbind(Connectivity, Habitat, Climate, Categ)
colnames(sem_path) = rownames(sem_path)

# blocks of indicators (outer model)

sem_blocks = list(c("Reg.hab.dens","Riv.net.disp.dist","Glac.lake.marine.dist","Time.since.glac"),
                  c("Surface.area","Max.depth","Secchi.depth","Prop.shield.litho"),
                  c("Clim.MWMT","Clim.MCMT","Clim.MSP","Clim.PAS"),
                  c("Categ"))

# non-metric scaling

sem_scaling <- list(c("NUM", "NUM", "NUM", "NUM"),
                    c("NUM", "NUM", "NUM", "NUM"),
                    c("NUM", "NUM", "NUM", "NUM"),
                    c("NOM"))

# run NM-PLS-SEM

set.seed(1)
sem_pls_categ = plspm(sitemods, sem_path, sem_blocks, modes = sem_modes, scaling = sem_scaling, scaled = TRUE,
                        scheme = "path", boot.val = TRUE, br = 1000)
summary(sem_pls_categ)

# capture categorical latent variable scores

sem_pls_categ_scores <- sem_pls_categ$scores

